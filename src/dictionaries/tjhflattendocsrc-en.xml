<!--  Syntax -->
<entry key="syntax.title">Syntax:</entry>
<entry key="syntax.opt_in">{0} [&lt;option&gt;]+ &lt;TeX file&gt; &lt;out-dir&gt;</entry>
<entry key="syntax.general">General Options:</entry>
<entry key="syntax.in">{0} (or {1}) &lt;TeX file&gt;	Parse &lt;TeX file&gt;.</entry>
<entry key="syntax.in.charset">{0} &lt;charset&gt;	Set the character encoding to &lt;charset&gt; for the input files. (Overrides default.)</entry>
<entry key="syntax.output.options">Output Options:</entry>
<entry key="syntax.out">{0} (or {1}) &lt;directory&gt;	Save output in &lt;directory&gt;.</entry>
<entry key="syntax.out.charset">{0} &lt;charset&gt;	Set the character encoding to &lt;charset&gt; for the output files. (Overrides default.)</entry>
<entry key="syntax.out.image-dest">{0} &lt;directory&gt;	Save output images in &lt;directory&gt; (relative to the output directory).</entry>

