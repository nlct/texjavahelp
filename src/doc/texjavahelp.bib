}

@command{includeimg,
 name={\csfmt{include\-img}},
 syntax={\oargm{options}\margm{basename}},
 description={Behaves like \gls{includegraphics} if
\metafilefmt{}{basename}{.tex} does not exist, otherwise sets the
input path to the same as for \gls{includegraphics} and inputs
\metafilefmt{}{basename}{.tex}}
}

@option{opt.includeimg.scale,
 name={\optfmt{scale}},
 parent={includeimg},
 syntax={\meta{value}},
 description={scale the image by \meta{value}}
}

@option{opt.includeimg.rotate,
 name={\optfmt{rotate}},
 parent={includeimg},
 syntax={\meta{angle}},
 description={rotate the image by \meta{angle}}
}

@option{opt.includeimg.width,
 name={\optfmt{width}},
 parent={includeimg},
 syntax={\meta{value}},
 description={scale the image so that the width is \meta{value}}
}

@option{opt.includeimg.height,
 name={\optfmt{height}},
 parent={includeimg},
 syntax={\meta{value}},
 description={scale the image so that the height is \meta{value}}
}

@option{opt.includeimg.frame,
 name={\optfmt{frame}},
 parent={includeimg},
 syntax={\meta{boolean}},
 description={if true, place a frame around the image}
}

@option{opt.includeimg.alt,
 name={\optfmt{alt}},
 parent={includeimg},
 syntax={\meta{text}},
 description={set the alt text (\gls{TeXParserLib} only, unless
implemented by \gls{includegraphics})}
}

@option{opt.includeimg.actualtext,
 name={\optfmt{actual\-text}},
 parent={includeimg},
 syntax={\meta{text}},
 description={set the actual text (\gls{TeXParserLib} only, unless
implemented by \gls{includegraphics})}
}

@option{opt.includeimg.artifact,
 name={\optfmt{arti\-fact}},
 parent={includeimg},
 syntax={\meta{boolean}},
 description={identifies image as an artifact (\gls{TeXParserLib} only, unless
implemented by \gls{includegraphics})}
}

@command{includetimg,
 name={\csfmt{include\-t\-img}},
 syntax={\oargm{options}\margm{basename}},
 description={as \gls{includeimg} but top-aligns the image}
}

@command{TeXParserLibToImagePreamble,
 name={\csfmt{TeX\-Par\-ser\-Lib\-To\-Image\-Pre\-amble}},
 description={If defined, the value of this token list variable will
be added to the document preamble used to create the image for
\gls{TeXParserLibToImage}}
}

@command{TeXParserLibToImage,
 name={\csfmt{TeX\-Par\-ser\-Lib\-To\-Image}},
 syntax={\oargm{options}\margm{\LaTeX\ code}},
 description={Just does \meta{\LaTeX\ code} when compiling with
\LaTeX\ but the \gls{TeXParserLib} will attempt to convert
the supplied code to an image}
}

@option{opt.TeXParserLibToImage.alt,
 name={\optfmt{alt}},
 parent={TeXParserLibToImage},
 syntax={\meta{text}},
 description={set the alt text. If not set, the \LaTeX\ code will be
used}
}

@option{opt.TeXParserLibToImage.pre-alt,
 name={\optfmt{pre\dhyphen alt}},
 parent={TeXParserLibToImage},
 syntax={\meta{text}},
 description={if set, inserts \meta{text} at the start of the alt
text}
}

@option{opt.TeXParserLibToImage.post-alt,
 name={\optfmt{post\dhyphen alt}},
 parent={TeXParserLibToImage},
 syntax={\meta{text}},
 description={if set, inserts \meta{text} at the end of the alt
text}
}

@option{opt.TeXParserLibToImage.name,
 name={\optfmt{name}},
 parent={TeXParserLibToImage},
 syntax={\meta{basename}},
 description={set the image file basename to \meta{basename}. If not
set, a generic basename is used in the form \metafilefmt{img}{n}{}}
}

@option{opt.TeXParserLibToImage.type,
 name={\optfmt{type}},
 parent={TeXParserLibToImage},
 syntax={\meta{mime-type}},
 description={identifies the type of image to create, where
\meta{mime-type} should be a supported image MIME type
(\code{image/png}, \code{image/jpeg} or \code{application/pdf})}
}

@option{opt.TeXParserLibToImage.crop,
 name={\optfmt{crop}},
 parent={TeXParserLibToImage},
 syntax={\meta{boolean}},
 description={indicates whether or not to crop the image}
}

@option{opt.TeXParserLibToImage.div,
 name={\optfmt{div}},
 parent={TeXParserLibToImage},
 syntax={\meta{value}},
 initval={false},
 defaultval={true},
 description={indicates whether or not to encapsulate the image in a
\code{div} element. The value may be boolean (\optfmt{true} or
\optfmt{false}) or the CSS class name}
}

