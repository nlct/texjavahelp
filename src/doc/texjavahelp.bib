  description={a Java library provided by Sun that could be used by Java
applications to a help system using Swing components. Its home page
was \nolinkurl{http://java.sun.com/products/javahelp}, but is no longer available}
}

@abbreviation{TeXJavaHelp,
  short={TJH},
  long={\NoCaseChange{\TeX}\ Java Help},
  description={a system that includes a library and an accompanying set of command line
tools to create an in-application help system for Java
\gls{gui}
applications where the help source is supplied as a \LaTeX\
document.
The library also provides methods to implement localisation support
for both \gls{gui} and \gls{cli} applications, and a \code{TeXApp}
class for applications that use the \gls{TeXParserLib}.}
}

