}

@application{app.xml2bib,
 name={\appfmt{xml\-2\-bib}},
 syntax={\oargm{options} \meta{XML-file}+}
}

@switch{switch.xml2bib.help,
  parent={app.xml2bib},
  shortswitch={h},
  description={Prints help and exits}
}

@switch{switch.xml2bib.version,
  parent={app.xml2bib},
  shortswitch={v},
  description={Prints version information and exits}
}

@switch{switch.xml2bib.in,
  parent={app.xml2bib},
  shortswitch={i},
  syntax={\meta{XML-file}},
  description={add \meta{XML-file} to the list of input files
(cumulative)}
}

@switch{switch.xml2bib.output,
  parent={app.xml2bib},
  shortswitch={o},
  syntax={\meta{BIB-file}},
  description={specifies \meta{BIB-file} as the output file}
}

@switch{switch.xml2bib.out-charset,
  parent={app.xml2bib},
  syntax={\meta{charset}},
  description={specifies \meta{charset} as the encoding for the output file}
}

@switch{switch.xml2bib.provide-xml,
  parent={app.xml2bib},
  description={copy XML source files from \app{xml2bib}['s] resource
directory if missing}
}

@switch{switch.xml2bib.copy-overwrite-xml,
  parent={app.xml2bib},
  description={copy XML source files from \app{xml2bib}['s] resource
directory if missing or if \app{xml2bib}['s] file is newer}
}

@switch{switch.xml2bib.debug,
  parent={app.xml2bib},
  description={switch on debug mode}
}

@switch{switch.xml2bib.nodebug,
  parent={app.xml2bib},
  description={switch off debug mode (default)}
}

@application{app.texjavahelpmk,
 name={\appfmt{tex\-java\-help\-mk}},
 syntax={\oargm{options} \meta{tex-file} \meta{out-dir}}
}

@switch{switch.help,
  parent={app.texjavahelpmk},
  shortswitch={h},
  description={Prints help and exits}
}

@switch{switch.version,
  parent={app.texjavahelpmk},
  shortswitch={v},
  description={Prints version information and exits}
}

@switch{switch.in,
  parent={app.texjavahelpmk},
  shortswitch={i},
  syntax={\meta{tex-file}},
  description={Specifies the input file}
}

@switch{switch.output,
  parent={app.texjavahelpmk},
  shortswitch={o},
  syntax={\meta{out-dir}},
  description={Specifies the output directory}
}

@switch{switch.image-dest,
  parent={app.texjavahelpmk},
  syntax={\meta{directory}},
  description={Save output images in \meta{directory} (relative to
the output directory)}
}

@switch{switch.out-charset,
  parent={app.texjavahelpmk},
  syntax={\meta{charset}},
  description={Set the character encoding to \meta{charset} for the
output files}
}

@switch{switch.html-ext,
  parent={app.texjavahelpmk},
  syntax={\meta{extension}},
  initvalue={html},
  description={Set the HTML file extension.}
}

@switch{switch.head,
  parent={app.texjavahelpmk},
  syntax={\meta{html}},
  description={Add \meta{html} code to the HTML header.}
}

@switch{switch.helpset,
  parent={app.texjavahelpmk},
  description={Create helpset files.}
}

@switch{switch.nohelpset,
  parent={app.texjavahelpmk},
  description={Create HTML5 files instead of helpset files.}
}

@switch{switch.image-preamble,
  parent={app.texjavahelpmk},
  syntax={\meta{\LaTeX\ code}},
  description={If an image needs to be automatically generated, set
the temporary \LaTeX\ file preamble to \meta{\LaTeX\ code}.}
}

@switch{switch.image-preamble-from-file,
  parent={app.texjavahelpmk},
  syntax={\meta{filename}},
  description={As \switch{image-preamble} but obtains content from
the file identified by \meta{filename}.}
}


@switch{switch.body-preamble,
  parent={app.texjavahelpmk},
  syntax={\meta{html}},
  description={Insert \meta{html} at the start of the HTML body.}
}

@switch{switch.body-preamble-from-file,
  parent={app.texjavahelpmk},
  syntax={\meta{filename}},
  description={As \switch{body-preamble} but obtains content from
the file identified by \meta{filename}.}
}

@switch{switch.body-postamble,
  parent={app.texjavahelpmk},
  syntax={\meta{html}},
  description={Insert \meta{html} at the end of the HTML body.}
}

@switch{switch.body-postamble-from-file,
  parent={app.texjavahelpmk},
  syntax={\meta{filename}},
  description={As \switch{body-postamble} but obtains content from
the file identified by \meta{filename}.}
}

@switch{switch.breadcrumbtrail,
  parent={app.texjavahelpmk},
  description={Add breadcrumb trail to start of HTML body.}
}

@switch{switch.nobreadcrumbtrail,
  parent={app.texjavahelpmk},
  description={Don't add breadcrumb trail to start of HTML body.}
}

@switch{switch.minitoc,
  parent={app.texjavahelpmk},
  description={Add minitoc to HTML body before the main content.}
}

@switch{switch.nominitoc,
  parent={app.texjavahelpmk},
  description={Don't add minitoc to HTML body.}
}

@switch{switch.minitoc-preamble,
  parent={app.texjavahelpmk},
  syntax={\meta{html}},
  description={Insert \meta{html} at the start of the minitoc.}
}

@switch{switch.minitoc-preamble-from-file,
  parent={app.texjavahelpmk},
  syntax={\meta{filename}},
  description={As \switch{minitoc-preamble} but obtains content from
the file identified by \meta{filename}.}
}

@switch{switch.minitoc-postamble,
  parent={app.texjavahelpmk},
  syntax={\meta{html}},
  description={Insert \meta{html} at the end of the minitoc.}
}

@switch{switch.minitoc-postamble-from-file,
  parent={app.texjavahelpmk},
  syntax={\meta{filename}},
  description={As \switch{minitoc-postamble} but obtains content from
the file identified by \meta{filename}.}
}

@switch{switch.minitoc-div-class,
  parent={app.texjavahelpmk},
  syntax={\meta{class-name}},
  initvalue={\initvalnotefmt{empty}},
  description={If \meta{class-name} not empty, encapsulate minitoc in a
div with the given class name.}
}

@switch{switch.minitoc-div-id,
  parent={app.texjavahelpmk},
  syntax={\meta{id-name}},
  initvalue={\initvalnotefmt{empty}},
  description={If \meta{id-name} not empty, encapsulate minitoc in a
div with the given id name.}
}

@switch{switch.mathjax,
  parent={app.texjavahelpmk},
  description={Add MathJax support.}
}

@switch{switch.nomathjax,
  parent={app.texjavahelpmk},
  description={Don't add MathJax support. This will just use an HTML
approximation which is quite limited. (Default, as
\code{HTMLDocument} doesn't support MathJax.)}
}

@switch{switch.support-unicode-script,
  parent={app.texjavahelpmk},
  description={Use Unicode superscripts or subscripts where
available.}
}

@switch{switch.nosupport-unicode-script,
  parent={app.texjavahelpmk},
  description={Don't use Unicode superscripts or subscripts, just
use \code{sub} or \code{sup} elements (default).}
}

@switch{switch.entities,
  parent={app.texjavahelpmk},
  description={Use HTML entities for non-ASCII characters.}
}

@switch{switch.noentities,
  parent={app.texjavahelpmk},
  description={Don't convert non-ASCII characters into HTML entities
(default).}
}

@switch{switch.convert-images,
  parent={app.texjavahelpmk},
  description={Use \pdfLaTeX\ or \LuaLaTeX\ to convert \LaTeX\ image files
(referenced with \gls{includeimg} etc) to bitmap images (default).}
}

@switch{switch.noconvert-images,
  parent={app.texjavahelpmk},
  description={Don't convert \LaTeX\ image files}
}

@switch{switch.prefix-split,
  parent={app.texjavahelpmk},
  description={Use the basename as a prefix for HTML files when
splitting on sections.}
}

@switch{switch.noprefix-split,
  parent={app.texjavahelpmk},
  description={Don't use the basename as a prefix for HTML files when
splitting on sections (default).}
}

@switch{switch.split,
  parent={app.texjavahelpmk},
  syntax={\meta{level}},
  initvalue={8},
  description={Set the split level (the sectioning depth to split
the document on).}
}


@switch{switch.log,
  parent={app.texjavahelpmk},
  syntax={\meta{filename}},
  description={Set the log file.}
}

@switch{switch.nolog,
  parent={app.texjavahelpmk},
  description={Don't log (default).}
}

@switch{switch.no-rm-tmp-dir,
  parent={app.texjavahelpmk},
  description={Don't remove temporary files on exit.}
}

@switch{switch.rm-tmp-dir,
  parent={app.texjavahelpmk},
  description={Remove temporary files on exit (default).}
}

@switch{switch.debug,
  parent={app.texjavahelpmk},
  syntax={\oargm{level}},
  description={Switch on debug mode}
}

@switch{switch.debug-mode,
  parent={app.texjavahelpmk},
  syntax={\meta{value}},
  description={Switch on debug mode for the given verbosity}
}

@switch{switch.nodebug,
  parent={app.texjavahelpmk},
  description={Switch off debug mode (default)}
}

@switch{switch.no-debug,
  parent={app.texjavahelpmk},
  description={synonym for \switch{nodebug}},
  alias={switch.nodebug}
}

