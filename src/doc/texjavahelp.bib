 description={similar to \gls{keydescref} but the description (if
set) is shown first}
}

@command{Desckeyref,
 providedby={\sty{texjavahelp}},
 syntax={\oargm{options}\margm{label}},
 description={as \gls{desckeyref} but the description (if set) will
be converted to sentence-case. There will be no case-change if
the description isn't set}
}

@command{newdglsfield,
 providedby={\sty{glossaries-extra-bib2gls}},
 name={\csfmt{new\-d\-gls\-field}},
 syntax={\oargm{default-options}\margm{field}\margm{cs}},
 description={defines the command
\meta{cs}\oargm{options}\margm{entry-label} to behave like
      \code{\gls{dglsfield}\oarg{\meta{default-options},\meta{options}}\margm{entry-label}\margm{field}}}
}

@command{newdglsfieldlike,
 providedby={\sty{glossaries-extra-bib2gls}},
 name={\csfmt{new\-d\-gls\-field\-like}},
 syntax={\oargm{default-options}\margm{field}\margm{cs}\margm{Cs}\margm{CS}},
 description={similar to \gls{newdglsfield} but also defines
     sentence-case (\meta{Cs}) and all-caps (\meta{CS}) commands
     with mappings}
}

@command{dglsfield,
 providedby={\sty{glossaries-extra-bib2gls}},
 name={\csfmt{dgls\-field}},
 modifiers={* +},
 syntax={\oargm{options}\margm{entry-label}\margm{field-label}\oargm{insert}},
 description={as \gls{dgls} but selects the first matching label that
     has an entry with the given field set}
}

@command{dgls,
 providedby={\sty{glossaries-extra-bib2gls}},
 modifiers={* +},
 syntax={\oargm{options}\margm{entry-label}\oargm{insert}},
 description={does \code{\gls{gls}\oargm{options}\marg{\meta{prefix}\marg{entry-label}}\oargm{insert}}
     for the first prefix in the prefix list that matches a defined entry}
}

@command{glsxtraddlabelprefix,
  providedby={\sty{glossaries-extra-bib2gls}},
  name={\csfmt{gls\-xtr\-add\-label\-pre\-fix}},
  syntax={\margm{label-prefix}},
  description={appends \meta{label-prefix} to the list of known
label prefixes}
}

@command{menutrail,
  providedby={\sty{texjavahelp}},
  syntax={\margm{entry-label}},
  modifiers={*},
  description={displays the menu trail for \meta{entry-label} using
its hierarchy with the separator given by \gls{menusep}}
}

@command{menu,
  providedby={\sty{texjavahelp}},
  syntax={\oargm{options}\oargm{label-prefix}\margm{label}},
  modifiers={*},
  description={uses \gls{menutrail} to display the menu trail for
the given entry identified by the prefixed label and then uses
\gls{glsadd} to index the entry. The \meta{label-prefix} defaults to \qtt{menu.} and
\meta{options} are as for \gls{glsadd}. The starred version will
prepend \optval{gls.format}{\glscsname{glsignore}} to the options}
}

@command{menuitem,
  providedby={\sty{texjavahelp}},
  syntax={\oargm{options}\oargm{label-prefix}\margm{entry-label}},
  modifiers={*},
  description={references a glossary entry using \gls{gls} but
locally redefines \gls{msgellipsis} to ignore its argument. The \meta{label-prefix} defaults to \qtt{menu.} and
\meta{options} are as for \gls{gls}. The starred version will
prepend \optval{gls.format}{\glscsname{glsignore}} to the options}
}

@command{menusep,
  providedby={\sty{texjavahelp}},
  description={symbol used as the separator for \gls{menutrail}}
}

@command{menuitemref,
  providedby={\sty{texjavahelp}},
  syntax={\margm{entry-label}},
  description={used for format each entry in \gls{menutrail}, where
\meta{entry-label} is the label of the current entry in the trail}
}

@command{glshyperlink,
  providedby={\sty{glossaries}},
  syntax={\oargm{text}\margm{entry-label}},
  description={creates a hyperlink to the given entry with the hyperlink
      text provided in the optional argument. If omitted the entry's
text field value is used for \meta{text}}
}

@command{TJHRequireIcons,
  name={\csfmt{TJH\-Require\-Icons}},
  providedby={\sty{texjavahelp}},
  syntax={\margm{list}\margm{small-suffix}\margm{large-suffix}},
  description={sets the small and large suffix and loads the
   corresponding icon map files (created by \app{tjhcreateiconpdf})
   \filemetametafmt{}{base}{-}{suffix}{.def} for each \meta{base}
   in the given \meta{list} and for each \meta{small-suffix} and
   \meta{large-suffix}}
}

@command{tjhmapiconimage,
  name={\csfmt{tjh\-map\-icon\-image}},
  providedby={\sty{texjavahelp}},
  syntax={\margm{resource
path}\margm{name}\margm{suffix}\margm{ext}\margm{pdf}\margm{page}},
  description={establishes an icon image mapping for the given
\meta{pdf}. This command is used in the mapping files loaded with
\gls{TJHRequireIcons} and created by \app{tjhcreateiconpdf}}
}

